# ══════════════════════════════════════════════════════════════════════════════
# trustr-service-orchestrator — environment configuration
# ══════════════════════════════════════════════════════════════════════════════

# ── Reconnect backoff ────────────────────────────────────────────────────────
# Exponential backoff for relay WebSocket reconnections.
# RECONNECT_BASE_MS=1000
# RECONNECT_MAX_MS=60000

# ── Storage ──────────────────────────────────────────────────────────────────
# Directory for the SQLite database (subscriptions, request keys).
# Default: ./data
# STORAGE_DIR=./data

# ── Announcement refresh ─────────────────────────────────────────────────────
# How often (ms) to re-fetch and re-publish service announcements.
# Default: 21600000 (6 hours)
# ANNOUNCE_INTERVAL_MS=21600000

# ══════════════════════════════════════════════════════════════════════════════
# TSM Service 1 — GrapeRank WoT
# ══════════════════════════════════════════════════════════════════════════════
TSM_SERVICE_1_NAME=Trustr GrapeRank
TSM_SERVICE_1_SERVICE_ID=trustr_graperank

# Hex private key for this service. The orchestrator derives the pubkey and
# uses this key to sign announcements, output events, and feedback events.
TSM_SERVICE_1_PRIVKEY=<hex-privkey>

# Provider pubkey mode (see TSM spec Appendix 2):
#   public_service       — open access, no authorization required (default)
#   subscription_service — managed keypairs per user, persistent access
#   restricted_service   — managed keypairs per request grant, single-use
# TSM_SERVICE_1_PUBKEY_MODE=public_service

# Expected output event kinds (comma-separated). Default: 37573
TSM_SERVICE_1_OUTPUT_KINDS=37573

# Service module HTTP endpoint (base URL, no trailing path).
# Same-droplet: http://127.0.0.1:3001
# Separate droplet in same DO VPC: http://10.x.x.x:3001
TSM_SERVICE_1_ENDPOINT=http://127.0.0.1:3001

# Relays to subscribe on for incoming kind 37572 requests (comma-separated).
TSM_SERVICE_1_LISTEN_RELAYS=wss://relay.primal.net,wss://relay.damus.io

# Relays to publish announcements (kind 37570), output (kind 37573),
# and feedback (kind 7000) events to (comma-separated).
# Output is ALSO published to any relay specified in the request's `r` tag.
TSM_SERVICE_1_PUBLISH_RELAYS=wss://relay.primal.net,wss://relay.damus.io

# ══════════════════════════════════════════════════════════════════════════════
# TSM Service 2 — Semantic Ranking (example)
# ══════════════════════════════════════════════════════════════════════════════
# TSM_SERVICE_2_NAME=Semantic Ranking
# TSM_SERVICE_2_SERVICE_ID=semantic_ranking
# TSM_SERVICE_2_PRIVKEY=<hex-privkey>
# TSM_SERVICE_2_PUBKEY_MODE=public_service
# TSM_SERVICE_2_OUTPUT_KINDS=37573
# TSM_SERVICE_2_ENDPOINT=http://127.0.0.1:3002
# TSM_SERVICE_2_LISTEN_RELAYS=wss://relay.example.com
# TSM_SERVICE_2_PUBLISH_RELAYS=wss://relay.example.com
